# Test Environment Variables
NODE_ENV=test
PORT=3001
API_VERSION=v1

# Test Database
DATABASE_URL="postgresql://aidlink:aidlink_password@localhost:5432/aidlink_test?schema=public"

# Test Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# Test JWT
JWT_SECRET=test_jwt_secret_for_testing_only
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Test Email (use a testing service)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=test_user
SMTP_PASSWORD=test_password
EMAIL_FROM=noreply@aidlink.test

# Test Soroban
SOROBAN_NETWORK_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
CONTRACT_ADDRESS=

# Rate Limiting (disabled for tests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=error
LOG_FILE_PATH=logs

# BullMQ
BULLMQ_REDIS_HOST=localhost
BULLMQ_REDIS_PORT=6379
BULLMQ_REDIS_PASSWORD=

# WebSocket
WS_PORT=3002

# Monitoring
HEALTH_CHECK_INTERVAL=30000
